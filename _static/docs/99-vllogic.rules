$ cat /etc/udev/rules.d/99-vllogic.rules
#
#   Step 1: copy to /etc/udev/rules.d/99-vllogic.rules
#           sudo cp ./99-vllogic.rules /etc/udev/rules.d/
#   Step 2: "sudo udevadm control --reload-rules"
#   Step 3: "sudo udevadm trigger"
#   Step 4: unplug your device and plug it back in
#

ACTION!="add", SUBSYSTEM!="usb_device", GOTO="vllogic_rules_end"

SUBSYSTEM=="usb", ATTRS{idVendor}=="1209", ATTRS{idProduct}=="6666", MODE="666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="0d28", ATTRS{idProduct}=="0204", MODE="666"

SUBSYSTEM=="usb", ATTRS{idVendor}=="1209", ATTRS{idProduct}=="2512", MODE="0666"
KERNEL=="hidraw*", ATTRS{idVendor}=="1209", ATTRS{idProduct}=="2512", MODE="0666"

KERNEL=="ttyACM[0-9]*", MODE="666"

LABEL="vllogic_rules_end"